    <string name="guide_what_title">What This App Does</string>
    <string name="guide_what_body">Turns your phone into a USB drive. When connected to a computer via USB, the computer sees a disk image on your phone as a real USB storage device. Create pre-formatted images that work instantly, or mount existing .img and .iso files.\n\nThe benefit is on the computer side: your phone acts as the hardware, and any PC you plug into sees a real USB disk. No drivers, no MTP, no special software needed on the computer.</string>
    <string name="guide_before_title">Before You Start</string>
    <string name="guide_before_1">Root access required (KernelSU, Magisk, or APatch)</string>
    <string name="guide_before_2">Grant root permission to this app in your root manager</string>
    <string name="guide_before_3">Connect your phone to a computer via USB cable</string>
    <string name="guide_mount_title">Mounting a Disk Image</string>
    <string name="guide_mount_1">Tap the + button on the main screen</string>
    <string name="guide_mount_2">Tap \"Select disk image file\" and pick your .img or .iso</string>
    <string name="guide_mount_3">Select type: Read-Write (USB stick), Read-Only (write-protected), or CD-ROM (for ISOs)</string>
    <string name="guide_mount_4">Tap \"Mount\". The computer detects a new USB device within seconds.</string>
    <string name="guide_mount_5">To eject: tap the eject icon on the device card.</string>
    <string name="guide_create_title">Creating a New Image</string>
    <string name="guide_create_1">Tap +, then \"Create new disk image\"</string>
    <string name="guide_create_2">Pick a size from the presets, or enter a custom size</string>
    <string name="guide_create_3">Choose a format: FAT32 (recommended), exFAT (for large files), or None (raw)</string>
    <string name="guide_create_4">Tap \"Create &amp; Mount\". The image is created, formatted, and mounted automatically.</string>
    <string name="guide_create_5">The computer detects a ready-to-use USB drive within seconds. No manual formatting needed.</string>
    <string name="guide_multi_title">Multiple Devices</string>
    <string name="guide_multi_body">Mount up to 8 devices simultaneously. Each appears as a separate USB device on the computer. Tap a device card to change its type or remove it.</string>
    <string name="guide_issues_title">Common Issues</string>
    <string name="guide_issue_daemon">Daemon not running</string>
    <string name="guide_issue_daemon_fix">Reboot your device, or go to Settings and tap Restart Daemon.</string>
    <string name="guide_issue_root">Root not granted</string>
    <string name="guide_issue_root_fix">Open your root manager (KSU/Magisk) and grant this app root access.</string>
    <string name="guide_issue_usb">Computer doesn\'t detect USB</string>
    <string name="guide_issue_usb_fix">Reconnect the cable. Check that USB debugging isn\'t overriding gadget mode.</string>
    <string name="guide_issue_appfuse">AppFuse proxy</string>
    <string name="guide_issue_appfuse_fix">Your file picker is proxying the file. Use a different file manager (not Google Files).</string>
